{
  "ConnectionStrings": {
    "Identity": "",
    "AcademicCatalog": "",
    "QuestionBank": "",
    "Students": "",
    "Commerce": ""
  },
  "DatabaseInitialization": {
    "AutoMigrate": false,
    "Seed": false
  },
  "Proxy": {
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimits": {
    "GlobalConcurrency": 200,
    "ReceiptUploadPermits": 5,
    "ReceiptUploadWindowMinutes": 10,
    "ReceiptReviewPermits": 30,
    "ReceiptReviewWindowMinutes": 1
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  },
  "Jwt": {
    "Issuer": "https://api.adeeb.tj",
    "Audience": "adeeb-mobile",
    "SigningKey": "",
    "AccessTokenMinutes": 10
  },
  "RefreshTokens": {
    "LifetimeDays": 30,
    "TokenBytes": 64
  },
  "PrivateFileStorage": {
    "Provider": "Local",
    "LocalRoot": "data/private"
  },
  "LegacyReceiptMigration": {
    "Enabled": false,
    "DryRun": true
  },
  "PasswordPolicy": {
    "MinimumLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true
  },
  "Documentation": {
    "Enabled": false,
    "RequireAuthorization": true,
    "DocsRoot": "docs"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
