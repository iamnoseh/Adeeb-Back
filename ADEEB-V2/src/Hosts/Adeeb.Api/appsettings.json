{
  "ConnectionStrings": {
    "Identity": ""
  },
  "Jwt": {
    "Issuer": "https://api.adeeb.tj",
    "Audience": "adeeb-mobile",
    "SigningKey": "replace-with-a-secure-32-byte-minimum-secret",
    "AccessTokenMinutes": 10
  },
  "RefreshTokens": {
    "LifetimeDays": 30,
    "TokenBytes": 64
  },
  "PasswordPolicy": {
    "MinimumLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
